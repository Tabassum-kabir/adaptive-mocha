# Copy this to .env and fill in real values.
# Provider can be: openai | anthropic | ollama | mock
AM_PROVIDER=mock

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# Ollama (local, CPU-friendly small model)
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=phi3:mini

# Token budget cap per participant session (USD-equivalent or token count)
AM_TOKEN_BUDGET=200000

# Study config (copy this file to .env — the app only reads .env)
# 1200 = 20 min (real study); 120 = 2 min (quick test)
AM_BLOCK_SECONDS=120
AM_PRACTICE_SECONDS=180
AM_DOMAIN=d1                   # default; overridden per session
AM_RANDOM_SEED=20260517
